{
  "name": "@jayethian/axiom",
  "version": "0.1.3",
  "maintainers": [
    "Jayetheus"
  ],
  "description": "A resilient, offline-first fetch wrapper for React Native & Next.js.",
  "keywords": [
    "react-native",
    "nextjs",
    "fetch",
    "axios",
    "offline-first",
    "sync",
    "network",
    "queue",
    "indexeddb"
  ],
  "homepage": "https://github.com/jayethian/axiom#readme",
  "bugs": {
    "url": "https://github.com/jayethian/axiom/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayethian/axiom.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "author": "Jayetheus",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  }
}