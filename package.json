{
  "name": "@jayethian/axiom",
  "version": "0.2.0",
  "maintainers": [
    "Jayetheus"
  ],
  "description": "Offline-first fetch with persistent queueing, backoff, idempotency, and React helpers.",
  "keywords": [
    "react",
    "react-native",
    "nextjs",
    "typescript",
    "fetch",
    "offline-first",
    "offline",
    "sync",
    "retry",
    "backoff",
    "idempotency",
    "network",
    "queue",
    "indexeddb"
  ],
  "homepage": "https://github.com/jayetheus/axiom#readme",
  "bugs": {
    "url": "https://github.com/jayetheus/axiom/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayetheus/axiom.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE*"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "author": "Jayetheus",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  }
}